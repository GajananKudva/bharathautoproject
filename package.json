{
  "name": "bharath-auto-trainer",
  "version": "1.0.0",
  "description": "Bharath Auto Sales Trainer — Maruti Suzuki Arena",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "start:desktop": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.bharathauto.trainer",
    "productName": "Bharath Auto Trainer",
    "copyright": "Bharath Auto — Maruti Suzuki Arena",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "manifest.json",
      "logo.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bharath Auto Trainer"
    }
  }
}
